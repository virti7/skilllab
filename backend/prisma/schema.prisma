generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  role          Role           @default(STUDENT)
  instituteId   String?
  createdAt     DateTime       @default(now())
  answers       Answer[]
  batchStudents BatchStudent[]
  results       Result[]
  institute     Institute?     @relation(fields: [instituteId], references: [id])

  @@map("users")
}

model Institute {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  batches   Batch[]
  tests     Test[]
  users     User[]

  @@map("institutes")
}

model Batch {
  id            String         @id @default(uuid())
  name          String
  inviteCode    String         @unique
  instituteId   String
  createdAt     DateTime       @default(now())
  batchStudents BatchStudent[]
  institute     Institute      @relation(fields: [instituteId], references: [id])
  tests         Test[]

  @@map("batches")
}

model BatchStudent {
  id       String   @id @default(uuid())
  batchId  String
  userId   String
  joinedAt DateTime @default(now())
  batch    Batch    @relation(fields: [batchId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([batchId, userId])
  @@map("batch_students")
}

model Test {
  id          String     @id @default(uuid())
  title       String
  duration    Int        @default(30)
  instituteId String
  batchId     String?
  expiryDate  DateTime?
  createdBy   String?
  createdAt   DateTime   @default(now())
  questions   Question[]
  results     Result[]
  batch       Batch?     @relation(fields: [batchId], references: [id])
  institute   Institute  @relation(fields: [instituteId], references: [id])

  @@map("tests")
}

model Question {
  id            String   @id @default(uuid())
  testId        String
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption String
  createdAt     DateTime @default(now())
  answers       Answer[]
  test          Test     @relation(fields: [testId], references: [id])

  @@map("questions")
}

model Result {
  id          String   @id @default(uuid())
  userId      String
  testId      String
  score       Int
  totalMarks  Int
  percentage  Float
  submittedAt DateTime @default(now())
  answers     Answer[]
  test        Test     @relation(fields: [testId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, testId])
  @@map("results")
}

model Answer {
  id             String   @id @default(uuid())
  resultId       String
  questionId     String
  selectedOption String
  isCorrect      Boolean
  userId         String
  question       Question @relation(fields: [questionId], references: [id])
  result         Result   @relation(fields: [resultId], references: [id])
  user           User     @relation(fields: [userId], references: [id])

  @@map("answers")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STUDENT
}
